{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/proposal-ingest/proposal_metadata.schema.json",
  "title": "Proposal Ingest Proposal Metadata",
  "type": "object",
  "required": [
    "schema_version",
    "proposal_id",
    "year_folder",
    "proposal_branch",
    "canonical_identity"
  ],
  "properties": {
    "schema_version": { "type": "string", "default": "0.1.0" },
    "proposal_id": { "type": "string" },
    "year_folder": { "type": "string" },
    "proposal_branch": { "type": "string" },
    "run_id": { "type": ["string", "null"] },
    "canonical_identity": {
      "type": "object",
      "required": ["proposal_name"],
      "properties": {
        "proposal_name": { "type": "string" },
        "proposal_short_name": { "type": ["string", "null"] },
        "agency": { "type": "string" },
        "agency_subunit": { "type": ["string", "null"] },
        "program": { "type": "string" },
        "phase": { "type": ["string", "null"] },
        "topic_number": { "type": ["string", "null"] },
        "topic_title": { "type": ["string", "null"] },
        "solicitation_number": { "type": ["string", "null"] },
        "submission_date": { "type": ["string", "null"] },
        "selection_notification_date": { "type": ["string", "null"] },
        "award_date": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "award_status": { "type": "string" },
        "award_amount": { "type": ["number", "null"] }
      },
      "additionalProperties": true
    },
    "organizations": {
      "type": "object",
      "properties": {
        "lead_organization": { "type": ["string", "null"] },
        "prime_or_sub": { "type": "string" },
        "partners": { "type": "array", "items": { "type": "string" } },
        "customer_or_sponsor": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "proposal_summary": {
      "type": "object",
      "properties": {
        "technical_objective": { "type": "string" },
        "proposed_approach": { "type": "string" },
        "target_applications": { "type": "array", "items": { "type": "string" } },
        "key_performance_targets": { "type": "array", "items": { "type": "string" } },
        "commercial_strategy": { "type": "string" },
        "reviewer_feedback": { "type": "array", "items": { "type": "string" } },
        "outcome": { "type": "string" }
      },
      "additionalProperties": true
    },
    "document_lineage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["document_id"],
        "properties": {
          "document_id": { "type": "string" },
          "file_name_original": { "type": ["string", "null"] },
          "document_role": { "type": "string" },
          "version_status": { "type": "string" },
          "authority_rank": { "type": "string" },
          "is_authoritative": { "type": "boolean" },
          "superseded_by_document_id": { "type": ["string", "null"] },
          "contains_unique_reasoning": { "type": "boolean" },
          "rationale": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "key_documents": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "knowledge_base_treatment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["document_id"],
        "properties": {
          "document_id": { "type": "string" },
          "recommended_rag_treatment": { "type": "string" },
          "rag_priority": { "type": "string" },
          "policy_applied": { "type": ["string", "null"] },
          "exception_reason": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "unresolved_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field"],
        "properties": {
          "field": { "type": "string" },
          "scope": { "type": "string" },
          "decision_type": { "type": "string" },
          "current_guess": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_summary": { "type": "string" },
          "affected_document_ids": { "type": "array", "items": { "type": "string" } },
          "downstream_impact": { "type": "string" },
          "reason_unresolved": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "tracker_match_status": { "type": "string" },
    "tracker_disagreements": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "synthesis_source": { "type": "string" },
    "document_count": { "type": "integer" }
  },
  "additionalProperties": true
}
